    "app.py": {
      "maxDuration": 60,
      "excludeFiles": "{.agents/**,.venv/**,__pycache__/**,**/*.pyc,**/*.pyo,tests/**,screenshots/**,exports/**,sample_logs/**,login_attempt_monitor.db,pandoc-*.msi,PROJECT_DOCS*.md,PROJECT_DOCS*.html,PROJECT_DOCS*.pdf}"
    }
  }
